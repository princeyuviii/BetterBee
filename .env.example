# ============================================================
# BetterBee — Environment Variables
# Copy to backend/.env and frontend/.env.local
# ============================================================

# --- App ---
APP_NAME=BetterBee
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# --- Database (Supabase PostgreSQL) ---
# For local dev with Docker: postgresql+asyncpg://postgres:postgres@localhost:5432/betterbee
DATABASE_URL=postgresql+asyncpg://postgres:YOUR_PASSWORD@db.YOUR_PROJECT.supabase.co:5432/postgres

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- AWS S3 (or MinIO for local dev) ---
S3_BUCKET_NAME=betterbee-documents
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
# For MinIO: S3_ENDPOINT_URL=http://localhost:9000
S3_ENDPOINT_URL=

# --- Clerk Authentication ---
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_JWKS_URL=https://YOUR_CLERK_DOMAIN/.well-known/jwks.json

# For frontend (.env.local):
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- AI Providers ---
# Active provider: groq | ollama | openai | anthropic | gemini
LLM_PROVIDER=groq
LLM_MODEL=llama-3.3-70b-versatile

# Active embedding provider: ollama | openai | gemini | huggingface
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text

# Provider API keys (only needed for active provider)
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Ollama (local)
OLLAMA_BASE_URL=http://localhost:11434

# --- ChromaDB (Persistent Client — no server needed) ---
CHROMA_PERSIST_DIR=./chroma_data
CHROMA_COLLECTION_PREFIX=workspace_

# --- RAG Configuration ---
RERANKER_PROVIDER=cross-encoder  # cross-encoder | none
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=20
RERANK_TOP_K=5
